generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  iduser   String    @id @db.Uuid
  username String    @db.VarChar(100)
  email    String    @unique @db.VarChar(320)
  password String    @db.VarChar(100)
  usertype UserType  @default(LOCATOR)
  booking  Booking[]
  home     Home[]

  @@index([username], map: "idx_user_username")
  @@map("user")
}

model Home {
  idhome      String @id @db.Uuid
  namehome    String @db.VarChar(100)
  description String
  price       Int

  address    String @db.VarChar(255)
  city       String @db.VarChar(100)
  postalcode String @db.VarChar(10)
  country    String @db.VarChar(100)

  iduser        String          @db.Uuid
  booking       Booking[]
  disponibility Disponibility[]
  user          User            @relation(fields: [iduser], references: [iduser], onDelete: Cascade, onUpdate: NoAction, map: "fk_home_user")
  home_image    HomeImage[]
  propertyType  PropertyType    @map("property_type")

  @@index([price], map: "idx_home_price")
  @@index([iduser], map: "idx_home_iduser")
  @@index([namehome], map: "idx_home_namehome")
  @@index([city], map: "idx_home_city")
  @@index([postalcode], map: "idx_home_postalcode")
  @@index([propertyType], map: "idx_home_propertytype")
  @@map("home")
}

model Booking {
  idbooking String   @id @db.Uuid
  startdate DateTime @db.Date
  enddate   DateTime @db.Date
  iduser    String   @db.Uuid
  idhome    String   @db.Uuid
  home      Home     @relation(fields: [idhome], references: [idhome], onDelete: Cascade, onUpdate: NoAction, map: "fk_booking_home")
  user      User     @relation(fields: [iduser], references: [iduser], onDelete: Cascade, onUpdate: NoAction, map: "fk_booking_user")

  @@index([idhome], map: "idx_booking_idhome")
  @@index([iduser], map: "idx_booking_iduser")
  @@map("booking")
}

model Disponibility {
  iddisponibility Int      @id @default(autoincrement())
  startdate       DateTime @db.Date
  enddate         DateTime @db.Date
  idhome          String   @db.Uuid
  home            Home     @relation(fields: [idhome], references: [idhome], onDelete: Cascade, onUpdate: NoAction, map: "fk_dispo_home")

  @@index([idhome], map: "idx_disponibility_idhome")
  @@map("disponibility")
}

model HomeImage {
  idimage  String @id @db.Uuid
  idhome   String @db.Uuid
  imageurl String @db.VarChar(500)
  imagekey String @db.VarChar(500)
  ordernum Int?   @default(0)
  home     Home   @relation(fields: [idhome], references: [idhome], onDelete: Cascade, onUpdate: NoAction, map: "fk_image_home")

  @@index([idhome], map: "idx_homeimage_idhome")
  @@map("home_image")
}

enum UserType {
  LOCATOR
  OWNER
  ADMIN
}

enum PropertyType {
  APARTMENT
  HOUSE
  STUDIO
  VILLA
  COTTAGE
  LOFT
  CHALET

  @@map("property_type")
}
