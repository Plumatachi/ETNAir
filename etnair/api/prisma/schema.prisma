// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserType {
  LOCATOR
  OWNER
}

model User {
  idUser   String   @id @default(uuid()) @db.Uuid
  username String   @db.VarChar(100)
  email    String   @unique @db.VarChar(320)
  password String   @db.VarChar(100)
  userType UserType @default(LOCATOR)

  homes    Home[]
  bookings Booking[]

  @@index([username], name: "idx_user_username")
  @@map("user")
}

model Home {
  idHome      String @id @default(uuid()) @db.Uuid
  nameHome    String @db.VarChar(100)
  description String @db.Text
  price       Int
  idUser      String @db.Uuid

  user            User            @relation(fields: [idUser], references: [idUser], onDelete: Cascade)
  bookings        Booking[]
  disponibilities Disponibility[]
  images          HomeImage[]

  @@index([nameHome], name: "idx_home_nameHome")
  @@index([price], name: "idx_home_price")
  @@index([idUser], name: "idx_home_idUser")
  @@map("home")
}

model Booking {
  idBooking String   @id @default(uuid()) @db.Uuid
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  idUser    String   @db.Uuid
  idHome    String   @db.Uuid

  user User @relation(fields: [idUser], references: [idUser], onDelete: Cascade)
  home Home @relation(fields: [idHome], references: [idHome], onDelete: Cascade)

  @@index([idUser], name: "idx_booking_idUser")
  @@index([idHome], name: "idx_booking_idHome")
  @@map("booking")
}

model Disponibility {
  idDisponibility Int      @id @default(autoincrement())
  startDate       DateTime @db.Date
  endDate         DateTime @db.Date
  idHome          String   @db.Uuid

  home Home @relation(fields: [idHome], references: [idHome], onDelete: Cascade)

  @@index([idHome], name: "idx_disponibility_idHome")
  @@map("disponibility")
}

model HomeImage {
  idImage  String @id @default(uuid()) @db.Uuid
  idHome   String @db.Uuid
  imageUrl String @db.VarChar(500)
  imageKey String @db.VarChar(500)
  orderNum Int    @default(0)

  home Home @relation(fields: [idHome], references: [idHome], onDelete: Cascade)

  @@index([idHome])
  @@map("home_image")
}
